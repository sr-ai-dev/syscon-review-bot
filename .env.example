# 로컬에서 봇을 실제 PR로 디버깅할 때 쓰는 env 예시.
# GitHub Actions에서는 runner와 action.yml이 모두 자동 주입하므로 이 파일이 필요 없음.
#
# 사용법: cp .env.example .env 후 값 채우고
#   set -a; source .env; set +a
#   .venv/bin/python -m src.cli

# --- 필수 ---

# 봇이 GitHub API 호출에 쓰는 토큰 (Personal Access Token 권장: repo, pull-requests scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# PR webhook payload JSON 파일 경로. 실 PR의 payload를 받아 저장해두고 그 경로 지정.
# 예: gh api repos/owner/repo/pulls/123 > /tmp/event.json 후 그 파일을 적당히 가공
GITHUB_EVENT_PATH=/tmp/pull_request_event.json

# Actions에서는 pull_request 이벤트일 때만 동작. 다른 값이면 봇이 skip
GITHUB_EVENT_NAME=pull_request

# OpenAI API 키
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# --- 선택 ---

# event payload에 repository.full_name이 없을 때 fallback
# GITHUB_REPOSITORY=owner/repo

# 기본 모델 오버라이드 (GPTClient의 default보다 우선)
# OPENAI_MODEL=gpt-5.4-mini

# 액션 입력 `model`에 해당. 설정되면 config의 model보다 우선
# REVIEW_MODEL_OVERRIDE=

# 대상 레포에서 읽을 review-bot.yml 경로
# REVIEW_CONFIG_PATH=.github/review-bot.yml

# 1로 두면 GPT/리뷰 submit 안 하고 system/user 프롬프트를 stdout으로 덤프
# 신규 룰·루브릭 변경 후 실제로 GPT에게 어떤 입력이 들어가는지 검증할 때 사용
# REVIEW_DRY_RUN=1
